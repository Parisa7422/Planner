{
  "name": "planner",
  "version": "1.0.0",
  "description": "A full-stack productivity planner app",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "server": "nodemon server",
    "client": "npm start --prefix client",
    "start": "node server.js",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "build": "npm install && npm install --prefix client && npm run build --prefix client",
    "heroku-postbuild": "npm run build"
  },
  "keywords": [],
  "author": "Parisa Tahery",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^7.2.1",
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^8.5.1",
    "morgan": "^1.10.0",
    "nodemon": "^2.0.16",
    "util": "^0.12.4",
    "validator": "^13.7.0"
  }
}
